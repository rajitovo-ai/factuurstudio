# Factuur Studio - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# These must be set for the application to function properly
# =============================================================================

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Admin Configuration
# Comma-separated list of admin email addresses
# These users get access to the /admin panel and can manually set user plans
VITE_ADMIN_EMAILS=admin@example.com,another-admin@example.com

# =============================================================================
# OPTIONAL VARIABLES
# These enhance functionality but are not strictly required
# =============================================================================

# Google Analytics (optional)
# Used for tracking pageviews and events
# Get from: https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# DEVELOPMENT ONLY
# These are only used in development mode
# =============================================================================

# Set to 'true' to enable additional debugging output
# VITE_DEBUG_MODE=false

# =============================================================================
# SUPABASE SECRETS (Server-side only)
# These are set via 'supabase secrets set' command, NOT in this file
# They are listed here for reference only
# =============================================================================

# Stripe Configuration (for Pro subscriptions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...

# Resend Email (for sending invoice emails)
# RESEND_API_KEY=re_...

# Application URL (for webhooks and redirects)
# APP_BASE_URL=https://factuurstudio.nl

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your Supabase credentials from:
#    https://app.supabase.com/project/_/settings/api
#
# 3. Add admin email addresses (comma-separated, no spaces)
#
# 4. (Optional) Add Google Analytics ID for tracking
#
# 5. For Stripe payments, set secrets via CLI:
#    supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#    supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#    supabase secrets set STRIPE_PRICE_PRO_MONTHLY=price_...
#    supabase secrets set STRIPE_PRICE_PRO_YEARLY=price_...
#    supabase secrets set APP_BASE_URL=https://factuurstudio.nl
#
# 6. Start the dev server:
#    npm run dev
